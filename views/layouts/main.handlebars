<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kila Dev | Modern SaaS Platform</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-spy="scroll" data-bs-target="#navbar-main" data-bs-offset="100">

    <nav id="navbar-main" class="navbar navbar-expand-lg navbar-dark fixed-top transition-all">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-rocket-takeoff-fill me-2 text-primary"></i>Kila <span class="text-primary">Dev</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto fw-medium">
                    <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
                    {{#if user}}
                        <li class="nav-item"><a class="nav-link" href="/board">Mi Tablero</a></li>
                        <li class="nav-item ms-lg-3">
                            <span class="nav-link text-white-50 small">Hola, {{user.username}}</span>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a href="/logout" class="btn btn-primary btn-sm rounded-pill px-4 py-2 mt-1">Cerrar Sesión</a>
                        </li>
                    {{else}}
                        <li class="nav-item"><a class="nav-link" href="/#features">Características</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#contact">Contacto</a></li>
                        <li class="nav-item ms-lg-3 mt-3 mt-lg-0">
                            <a class="btn btn-primary btn-sm rounded-pill px-4 py-2" href="/#hero">Probar Gratis</a>
                        </li>
                    {{/if}}
                </ul>
            </div>
        </div>
    </nav>

    <div class="content-wrapper {{#if isBoard}}pt-5 mt-5{{/if}}">
        {{{body}}}
    </div>

    <footer class="py-5 bg-black text-center border-top border-secondary border-opacity-10 mt-5">
        <div class="container">
            <div class="mb-4">
                <a class="navbar-brand fw-bold text-white fs-4" href="/">
                    <i class="bi bi-rocket-takeoff-fill me-2 text-primary"></i>Kila Dev
                </a>
            </div>
            <p class="text-white-50 mb-0 small">&copy; 2026 Kila Dev - Diseñando para el futuro.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/script.js"></script>
</body>
</html>
