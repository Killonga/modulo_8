<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold">Mi Tablero Kanban</h1>
    <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addTaskModal">
        <i class="bi bi-plus-lg me-2"></i>Nueva Tarea
    </button>
</div>

<div class="row g-4">
    <!-- TODO COLUMN -->
    <div class="col-md-4">
        <div class="kanban-col shadow-sm">
            <h5 class="fw-bold mb-4 d-flex justify-content-between align-items-center">
                <span>Por Hacer</span>
                <span class="badge bg-secondary rounded-pill" id="todo-count">0</span>
            </h5>
            <div id="col-todo" class="kanban-items"></div>
        </div>
    </div>
    <!-- IN PROGRESS COLUMN -->
    <div class="col-md-4">
        <div class="kanban-col shadow-sm border-top border-primary border-4">
            <h5 class="fw-bold mb-4 d-flex justify-content-between align-items-center">
                <span>En Progreso</span>
                <span class="badge bg-primary rounded-pill" id="progress-count">0</span>
            </h5>
            <div id="col-in-progress" class="kanban-items"></div>
        </div>
    </div>
    <!-- DONE COLUMN -->
    <div class="col-md-4">
        <div class="kanban-col shadow-sm border-top border-success border-4">
            <h5 class="fw-bold mb-4 d-flex justify-content-between align-items-center">
                <span>Completado</span>
                <span class="badge bg-success rounded-pill" id="done-count">0</span>
            </h5>
            <div id="col-done" class="kanban-items"></div>
        </div>
    </div>
</div>

<!-- Modal Nueva Tarea -->
<div class="modal fade" id="addTaskModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 auth-card">
            <div class="modal-header border-0 pb-0 px-4">
                <h5 class="modal-title fw-bold text-white mt-3">Crear Nueva Tarea</h5>
                <button type="button" class="btn-close mt-2" data-bs-dismiss="modal"></button>
            </div>
            <form id="addTaskForm">
                <div class="modal-body p-4">
                    <div class="mb-4">
                        <label class="form-label text-white-50 small ms-2">Título de la Tarea</label>
                        <input type="text" name="title" class="form-control rounded-pill p-3 px-4" required placeholder="Ej: Finalizar reporte">
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-white-50 small ms-2">Descripción</label>
                        <textarea name="description" class="form-control" placeholder="Escribe los detalles aquí..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white-50 small ms-2">Imagen de Portada (Opcional)</label>
                        <input type="file" name="image" class="form-control bg-dark text-white border-0 rounded-3" accept="image/*">
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 shadow-primary">Guardar Tarea <i class="bi bi-check-lg ms-2"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="/js/board.js"></script>

