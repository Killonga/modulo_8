<div class="row justify-content-center pt-5">
    <div class="col-md-5 mt-5">
        <div class="card shadow rounded-4 p-4">
            <h2 class="text-center mb-4">Iniciar Sesión</h2>
            <form id="loginForm">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control rounded-pill p-2 px-3" required placeholder="tu@email.com">
                </div>
                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input type="password" name="password" class="form-control rounded-pill p-2 px-3" required placeholder="********">
                </div>
                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 mt-3">Ingresar <i class="bi bi-arrow-right ms-2"></i></button>
            </form>
            <p class="text-center mt-4 text-muted small">¿No tienes cuenta? <a href="/register" class="text-decoration-none">Regístrate aquí</a></p>
            <div id="loginError" class="alert alert-danger mt-3 d-none"></div>
        </div>
    </div>
</div>

<script>
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        const errorDiv = document.getElementById('loginError');

        try {
            const res = await fetch('/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            if (res.ok) {
                window.location.href = '/board';
            } else {
                errorDiv.textContent = result.message || 'Error al iniciar sesión';
                errorDiv.classList.remove('d-none');
            }
        } catch (err) {
            console.error(err);
        }
    });
</script>
