<header id="hero" class="hero-section d-flex align-items-center">
    <div class="container position-relative z-1 text-center text-lg-start">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0 slide-up">
                <h1 class="display-3 fw-bold mb-3 text-white">Eleva tu productividad al <span
                        class="gradient-text">siguiente nivel</span>.</h1>
                <p class="lead text-white-50 mb-5">Kila Dev es la plataforma definitiva para gestionar tus proyectos con velocidad y simplicidad extrema.</p>
                <div class="d-flex flex-column flex-sm-row gap-3">
                    <a href="#features" class="btn btn-outline-light btn-lg rounded-pill px-5">Explorar Funciones</a>
                    <a href="#contact" class="btn btn-primary btn-lg rounded-pill px-5 shadow-primary">Saber Más</a>
                </div>
            </div>
            <div class="col-lg-5 offset-lg-1 slide-in-right">
                <div class="auth-card p-4 p-md-5 rounded-4 shadow-2xl">
                    <ul class="nav nav-pills auth-tabs mb-4 justify-content-center" id="authTab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="login-tab" data-bs-toggle="pill" data-bs-target="#login" type="button" role="tab">Entrar</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="register-tab" data-bs-toggle="pill" data-bs-target="#register" type="button" role="tab">Unirse</button>
                        </li>
                    </ul>
                    <div class="tab-content" id="authTabContent">
                        <!-- Login Form -->
                        <div class="tab-pane fade show active" id="login" role="tabpanel">
                            <form id="hero-loginForm">
                                <div class="mb-3">
                                    <label class="form-label text-white-50 small ms-2">Correo Electrónico</label>
                                    <input type="email" name="email" class="form-control rounded-pill p-3 px-4" required placeholder="tu@correo.com">
                                </div>
                                <div class="mb-4">
                                    <label class="form-label text-white-50 small ms-2">Contraseña</label>
                                    <input type="password" name="password" class="form-control rounded-pill p-3 px-4" required placeholder="********">
                                </div>
                                <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 shadow-primary">Ingresar <i class="bi bi-arrow-right ms-2"></i></button>
                                <div id="hero-loginError" class="alert alert-danger mt-3 d-none small"></div>
                            </form>
                        </div>
                        <!-- Register Form -->
                        <div class="tab-pane fade" id="register" role="tabpanel">
                            <form id="hero-registerForm">
                                <div class="mb-3">
                                    <label class="form-label text-white-50 small ms-2">Nombre de Usuario</label>
                                    <input type="text" name="username" class="form-control rounded-pill p-3 px-4" required placeholder="Ej: dev_pro">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-white-50 small ms-2">Correo Electrónico</label>
                                    <input type="email" name="email" class="form-control rounded-pill p-3 px-4" required placeholder="tu@correo.com">
                                </div>
                                <div class="mb-4">
                                    <label class="form-label text-white-50 small ms-2">Contraseña</label>
                                    <input type="password" name="password" class="form-control rounded-pill p-3 px-4" required placeholder="mín. 6 caracteres">
                                </div>
                                <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 shadow-primary">Crear Cuenta <i class="bi bi-person-plus ms-2"></i></button>
                                <div id="hero-registerError" class="alert alert-danger mt-3 d-none small"></div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Features Section -->
<section id="features" class="py-huge">
    <div class="container">
        <div class="text-center mb-huge">
            <h6 class="text-primary text-uppercase fw-bold ls-2">Características</h6>
            <h2 class="display-5 fw-bold text-white mb-4">¿Por qué elegir Kila Dev?</h2>
            <p class="text-white-50 max-w-600 mx-auto">Tecnología de vanguardia para gestionar tus tareas con fluidez.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card p-5 rounded-4 h-100 border border-secondary border-opacity-10 hover-up transition-all">
                    <div class="icon-square mb-4 bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-kanban"></i>
                    </div>
                    <h4 class="fw-bold mb-3 text-white">Tablero Dinámico</h4>
                    <p class="text-white-50">Gestiona tus tareas con una interfaz visual intuitiva y rápida.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card p-5 rounded-4 h-100 border border-secondary border-opacity-10 hover-up featured transition-all">
                    <div class="icon-square mb-4 bg-primary text-white shadow-primary">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h4 class="fw-bold mb-3 text-white">Privacidad Total</h4>
                    <p class="text-white-50">Tus tableros están seguros y son accesibles solo por ti.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card p-5 rounded-4 h-100 border border-secondary border-opacity-10 hover-up transition-all">
                    <div class="icon-square mb-4 bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-lightning-charge"></i>
                    </div>
                    <h4 class="fw-bold mb-3 text-white">Sincronización</h4>
                    <p class="text-white-50">Accede a tus tareas desde cualquier dispositivo en tiempo real.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" class="py-huge bg-black overflow-hidden position-relative">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="contact-card p-5 p-md-block rounded-5 shadow-2xl glass-effect border border-secondary border-opacity-25 fade-in">
                    <div class="text-center mb-5">
                        <h2 class="display-6 fw-bold text-white mb-3">Hablemos de tu próximo gran proyecto</h2>
                        <p class="text-white-50">Nuestro equipo está listo para ayudarte a despegar.</p>
                    </div>
                    <form id="contactForm" class="needs-validation" novalidate>
                        <div class="row g-4">
                            <div class="col-md-6 text-start">
                                <label for="name" class="form-label text-white-50 ms-2">Tu Nombre</label>
                                <input type="text" class="form-control rounded-pill p-3 px-4" id="name" required placeholder="Nombre completo">
                            </div>
                            <div class="col-md-6 text-start">
                                <label for="email" class="form-label text-white-50 ms-2">Correo Electrónico</label>
                                <input type="email" class="form-control rounded-pill p-3 px-4" id="email" required placeholder="ejemplo@correo.com">
                            </div>
                            <div class="col-12 text-start">
                                <label for="message" class="form-label text-white-50 ms-2">Mensaje</label>
                                <textarea class="form-control" id="message" rows="4" required placeholder="¿En qué podemos ayudarte?"></textarea>
                            </div>
                            <div class="col-12 text-center mt-5">
                                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 py-3 w-100 shadow-primary transition-all">Enviar Mensaje <i class="bi bi-send ms-2"></i></button>
                            </div>
                        </div>
                    </form>
                    <div id="formSuccess" class="alert alert-success mt-4 d-none">¡Mensaje enviado con éxito! Nos pondremos en contacto pronto.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // Hero Login Handler
    document.getElementById('hero-loginForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(e.target).entries());
        const errorDiv = document.getElementById('hero-loginError');
        try {
            const res = await fetch('/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            if (res.ok) window.location.href = '/board';
            else {
                errorDiv.textContent = result.message || 'Error al iniciar sesión';
                errorDiv.classList.remove('d-none');
            }
        } catch (err) { console.error(err); }
    });

    // Hero Register Handler
    document.getElementById('hero-registerForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(e.target).entries());
        const errorDiv = document.getElementById('hero-registerError');
        try {
            const res = await fetch('/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            if (res.ok) {
                // Auto login after register
                await fetch('/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: data.email, password: data.password })
                });
                window.location.href = '/board';
            } else {
                errorDiv.textContent = result.message || 'Error al registrarse';
                errorDiv.classList.remove('d-none');
            }
        } catch (err) { console.error(err); }
    });
</script>
